

var
   numero: inteiro

inicio
   escreva("Digite um número de 1 a 7: ")
   leia(numero)

   escolha (numero)
      caso 1
         escreva("Domingo")
      caso 2
         escreva("Segunda-feira")
      caso 3
         escreva("Terça-feira")
      caso 4
         escreva("Quarta-feira")
      caso 5
         escreva("Quinta-feira")
      caso 6
         escreva("Sexta-feira")
      caso 7
         escreva("Sábado")
      outrocaso
         escreva("Número inválido! Digite um valor entre 1 e 7.")
   fimescolha

fimalgoritmo
